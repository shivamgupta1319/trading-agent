# Copy this file to ".env" and fill in your key. The .env file is gitignored.

# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_key_here

# Optional: pick any tool-capable model from https://openrouter.ai/models
# FREE + tool-capable: meta-llama/llama-3.3-70b-instruct:free, qwen/qwen3-coder:free
# Paid Gemini (better): google/gemini-2.5-flash, google/gemini-2.5-pro
MODEL=meta-llama/llama-3.3-70b-instruct:free
